# ────────────────────────────────────────────────
# Morpho3D — Environment Configuration
# Copy this file to .env.local and fill in values
# ────────────────────────────────────────────────

# OpenAI API Key (Optional)
# Used for GPT-4o Vision image analysis (highest quality)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API Key (Optional)
# Used for Gemini Vision image analysis (high performance, free tier available)
# Get one at: https://aistudio.google.com/
GEMINI_API_KEY=

# Hugging Face Token (Optional but recommended)
# Increases rate limits for Stable Fast 3D and LLaVA
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=
